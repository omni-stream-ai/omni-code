  "children": [
    {
      "type": "frame",
      "name": "Omni Code - Entry States",
      "width": 2780,
      "height": 1400,
      "layout": "horizontal",
      "gap": 42,
      "padding": [
        64,
        72
      ],
      "alignItems": "center",
      "fill": [
        {
          "type": "solid",
          "color": "$--color-board"
        }
      ],
      "children": [
        {
          "type": "frame",
          "name": "01 Connect Bridge",
          "width": 300,
          "height": 820,
          "layout": "vertical",
          "gap": 12,
          "padding": [
            28,
            18,
            18,
            18
          ],
          "cornerRadius": 28,
          "fill": [
            {
              "type": "solid",
              "color": "$--color-screen"
            }
          ],
          "stroke": {
            "thickness": 1,
            "fill": "$--color-stroke",
            "align": "inside"
          },
          "effects": [
            {
              "type": "shadow",
              "offsetX": 0,
              "offsetY": 28,
              "blur": 50,
              "spread": 0,
              "color": "rgba(31,41,55,0.14)"
            }
          ],
          "children": [
            {
              "type": "frame",
              "name": "Connect Header",
              "width": "fill_container",
              "height": "fit_content",
              "layout": "vertical",
              "gap": 4,
              "children": [
                {
                  "type": "text",
                  "content": "OMNI CODE",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 24,
                  "fontWeight": 800,
                  "lineHeight": 1.1,
                  "letterSpacing": 0.6,
                  "fill": [
                    {
                      "type": "solid",
                      "color": "$--color-text"
                    }
                  ]
                },
                {
                  "type": "text",
                  "content": "Connect your Bridge to get started.",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": 500,
                  "lineHeight": 1.4,
                  "letterSpacing": 0.2,
                  "fill": [
                    {
                      "type": "solid",
                      "color": "$--color-muted"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "name": "Connect Content",
              "width": "fill_container",
              "height": "fill_container",
              "layout": "vertical",
              "gap": 10,
              "children": [
                {
                  "type": "frame",
                  "name": "Bridge Welcome Card",
                  "width": "fill_container",
                  "height": "fit_content",
                  "layout": "vertical",
                  "gap": 10,
                  "padding": 14,
                  "alignItems": "center",
                  "cornerRadius": 14,
                  "fill": [
                    {
                      "type": "solid",
                      "color": "$--color-panel"
                    }
                  ],
                  "stroke": {
                    "thickness": 1,
                    "fill": "$--color-stroke",
                    "align": "inside"
                  },
                  "effects": [
                    {
                      "type": "shadow",
                      "offsetX": 0,
                      "offsetY": 10,
                      "blur": 24,
                      "spread": 0,
                      "color": "rgba(17,24,39,0.06)"
                    }
                  ],
                  "children": [
                    {
                      "type": "frame",
                      "width": 44,
                      "height": 44,
                      "cornerRadius": 12,
                      "layout": "horizontal",
                      "justifyContent": "center",
                      "alignItems": "center",
                      "fill": [
                        {
                          "type": "solid",
                          "color": "#EEF4FF"
                        }
                      ],
                      "children": [
                        {
                          "type": "path",
                          "name": "ShieldOutlinedIcon",
                          "width": 20,
                          "height": 20,
                          "d": "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z",
                          "stroke": {
                            "thickness": 2,
                            "fill": [
                              {
                                "type": "solid",
                                "color": "$--color-accent-blue"
                              }
                            ]
                          },
                          "fill": []
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "content": "Welcome to Omni Code",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 14,
                      "fontWeight": 700,
                      "lineHeight": 1.3,
                      "letterSpacing": 0,
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-text"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "content": "Run the Bridge service on your computer, then authorize this device to open projects and continue sessions.",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": 500,
                      "lineHeight": 1.55,
                      "letterSpacing": 0,
                      "textAlign": "center",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-muted"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "name": "Bridge URL Card",
                  "width": "fill_container",
                  "height": "fit_content",
                  "layout": "vertical",
                  "gap": 8,
                  "padding": 12,
                  "cornerRadius": 12,
                  "fill": [
                    {
                      "type": "solid",
                      "color": "$--color-panel"
                    }
                  ],
                  "stroke": {
                    "thickness": 1,
                    "fill": "$--color-stroke",
                    "align": "inside"
                  },
                  "children": [
                    {
                      "type": "text",
                      "content": "Bridge URL",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": 700,
                      "lineHeight": 1.25,
                      "letterSpacing": 0.2,
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-text-soft"
                        }
                      ]
                    },
                    {
                      "type": "rectangle",
                      "width": "fill_container",
                      "height": 40,
                      "cornerRadius": 10,
                      "layout": "horizontal",
                      "alignItems": "center",
                      "padding": [
                        0,
                        12
                      ],
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-panel"
                        }
                      ],
                      "stroke": {
                        "thickness": 1,
                        "fill": "$--color-stroke",
                        "align": "inside"
                      },
                      "children": [
                        {
                          "type": "text",
                          "content": "http://127.0.0.1:8787",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": 600,
                          "lineHeight": 1.25,
                          "letterSpacing": 0,
                          "fill": [
                            {
                              "type": "solid",
                              "color": "$--color-text"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "content": "Use your computer IP if the phone is on the same LAN.",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 10,
                      "fontWeight": 500,
                      "lineHeight": 1.4,
                      "letterSpacing": 0,
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-muted"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "name": "Download Bridge Card",
                  "width": "fill_container",
                  "height": "fit_content",
                  "layout": "vertical",
                  "gap": 8,
                  "padding": 12,
                  "cornerRadius": 12,
                  "fill": [
                    {
                      "type": "solid",
                      "color": "$--color-warning-bg"
                    }
                  ],
                  "stroke": {
                    "thickness": 1,
                    "fill": "$--color-warning-stroke",
                    "align": "inside"
                  },
                  "children": [
                    {
                      "type": "text",
                      "content": "Download Bridge service",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 11,
                      "fontWeight": 700,
                      "lineHeight": 1.25,
                      "letterSpacing": 0.2,
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-warning-text"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "content": "Get the service from GitHub on the computer that hosts your local projects.",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 10,
                      "fontWeight": 500,
                      "lineHeight": 1.4,
                      "letterSpacing": 0,
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-warning-text"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "content": "github.com/omni-stream-ai/omni-code-bridge",
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 10,
                      "fontWeight": 700,
                      "lineHeight": 1.3,
                      "letterSpacing": 0,
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-warning-muted"
                        }
                      ]
                    },
                    {
                      "type": "rectangle",
                      "width": "fill_container",
                      "height": 36,
                      "cornerRadius": 999,
                      "layout": "horizontal",
                      "justifyContent": "center",
                      "alignItems": "center",
                      "fill": [
                        {
                          "type": "solid",
                          "color": "$--color-panel"
                        }
                      ],
                      "stroke": {
                        "thickness": 1,
                        "fill": "$--color-warning-stroke",
                        "align": "inside"
                      },
                      "children": [
                        {
                          "type": "text",
                          "content": "Open GitHub releases",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 11,
                          "fontWeight": 700,
                          "lineHeight": 1.25,
                          "letterSpacing": 0,
                          "fill": [
                            {
                              "type": "solid",
                              "color": "$--color-warning-text"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "name": "Authorize Block",
              "width": "fill_container",
              "height": "fit_content",
              "layout": "vertical",
              "gap": 8,
              "children": [
                {
                  "type": "rectangle",
                  "name": "Authorize Device Button",
                  "width": "fill_container",
                  "height": 48,
                  "cornerRadius": 10,
                  "layout": "horizontal",

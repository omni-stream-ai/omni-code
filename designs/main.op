            }
          ],
          "children": [
            {
              "type": "frame",
              "name": "Approval Header",
              "width": "fill_container",
              "height": "fit_content",
              "layout": "vertical",
              "gap": 4,
              "children": [
                {
                  "type": "text",
                  "content": "AUTHORIZATION",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 24,
                  "fontWeight": 800,
                  "lineHeight": 1.1,
